.DS_Store

test_should_be_ignored.txt

## PIPELINE INFO
pipeline_info/*.{html,json,txt,yml}

# FASTQC
**/*_fastqc*.{html,zip}

# FASTP (includes time usage)
*/*.fastp.{log,html}
*/*.{fail,fastp}.fastq.gz

# FGBIO_FASTQTOBAM and ALIGN_BAM
*/*.{bam,bai}
*.mapped.dup_marked.{bam,bai}

# MULTIQC
# Ignore the HTML report itself
{multiqc,multiqc/**}/multiqc_report.html

# Ignore plots and data files
{multiqc,multiqc/**}/multiqc_plots/**
{multiqc,multiqc/**}/multiqc_data/**
multiqc/multiqc_data/**
multiqc/*/multiqc_data/*.{log,json}
multiqc/*/multiqc_data/multiqc_fastqc.txt
multiqc/*/multiqc_data/multiqc_general_stats.txt
multiqc/*/multiqc_data/multiqc_software_versions.txt
multiqc/*/multiqc_data/multiqc_sources.txt
multiqc/*/multiqc_report.html
multiqc/multiqc_plots/png/*
multiqc/multiqc_plots/svg/*
multiqc/multiqc_plots/pdf/*
multiqc/multiqc_data/*

# PICARD_COLLECTMULTIPLEMETRICS and PICARD_MARKDUPLICATES
# PDF files and those that include timestamps
*/*.Collect*.*
*/*.MarkDuplicates.metrics.txt
*.MarkDuplicates.metrics.txt

# GATK
**/*.vcf.gz
**/*.tbi


# SnpEff
**/*.snpeff.vcf.gz
*.snpeff.vcf.gz
**/snpEff_summary.html
snpEff_summary.html
**/*.snpeff.csv

# TMB (includes timestamp -- this file is introspected separately)
**/*.tmb.log

# VEP
**/*.*_summary.html
**/*.vep.vcf.gz_summary.html
**/*.vep.vcf.gz

# CIVIC
**/*.civic.vcf


